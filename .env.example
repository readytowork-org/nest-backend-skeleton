ENVIRONMENT=local
TZ=Z

# Server
PORT=8080
ADMINER_PORT=5001

# Database
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_HOST=your_db_host
DB_NAME=your_db_name
DB_PORT=3306
DB_TYPE=mysql

# JWT
JWT_ACCESS_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d
JWT_ACCESS_EXPIRES_IN=1h

SYSTEM_EMAIL=admin@skeleton.com
SYSTEM_PASSWORD=password

ADMIN_FRONTEND_URL=http://localhost:3000
PLAYER_FRONTEND_URL=http://localhost:3001

# Google OAuth
GOOGLE_CLIENT_ID=google_client_id
GOOGLE_CLIENT_SECRET=google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8080/api/v1/auth/player/google/callback

FROM_EMAIL=your_from_email

STORAGE_BUCKET_NAME=your_storage_bucket_name

MAIL_CLIENT_ID=your_mail_client_id
MAIL_CLIENT_SECRET=your_mail_client_secret
MAIL_REFRESH_TOKEN=your_mail_refresh_token
MAIL_ACCESS_TOKEN=your_mail_access_token