# Server
PORT=8080
NODE_ENV=local
ADMINER_PORT=5001

# Database
DB_USERNAME=root
DB_PASSWORD=secret
DB_HOST=database
DB_NAME=nest_db
DB_PORT=3306
DB_TYPE=mysql

# JWT
JWT_ACCESS_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d
JWT_ACCESS_EXPIRES_IN=1h

SYSTEM_EMAIL=admin@fortuner.com
SYSTEM_PASSWORD=password

# Google OAuth
GOOGLE_CLIENT_ID=GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=GOOGLE_CALLBACK_URL
# Amazon OAuth
# IMPORTANT: Replace these with real values from your Amazon Developer Console
# Your app won't work with these placeholder values
AMAZON_CLIENT_ID=AMAZON_CLIENT_ID
AMAZON_CLIENT_SECRET=AMAZON_CLIENT_SECRET
AMAZON_CALLBACK_URL=AMAZON_CALLBACK_URL